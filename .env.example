# SSL Monitor SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SENDER_EMAIL=your-email@gmail.com

# Recipient Emails (comma-separated list for multiple addresses)
SMTP_RECEIVER_EMAILS=admin@example.com,alerts@example.com

# Secure access key for the Web Admin Dashboard (default is admin123 if not set)
DASHBOARD_PASSWORD=admin123
